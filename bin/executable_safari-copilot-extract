#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "beautifulsoup4>=4.12",
#   "markdownify>=0.13",
# ]
# ///

"""
Extract a GitHub Copilot chat transcript from the active Safari tab.

This version uses a simple state machine over the flattened AppleScript output:
- plain <p> blocks are semantic anchors
- ToolCodeBlock figure blocks are tool/log blocks
- <p> blocks whose text starts with [ or { are treated as JSON-like tool results
- prose blocks like "Now let me..." are assistant worklog/progress notes
- prose blocks like "I now have..." and "Updated timeline..." are treated as
  assistant final responses
- the first prose block is treated as the initial user prompt
- the first prose block after an assistant final is treated as a new user prompt

The goal is not perfect DOM reconstruction. It is to produce a useful markdown
transcript with stable enough structure for later cleanup.

Examples
--------
python safari_copilot_transcript.py
python safari_copilot_transcript.py --stdout
python safari_copilot_transcript.py --output copilot_chat.md
python safari_copilot_transcript.py --raw-json copilot_dom.json
"""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from dataclasses import dataclass, field
from html import unescape
from pathlib import Path
from typing import Any

from bs4 import BeautifulSoup
from markdownify import markdownify as md


APPLE_SCRIPT = r'''
tell application "Safari"
    if not (exists front document) then error "No Safari document open"

    set js to "
(() => {
  const main = document.querySelector('main') || document.body;

  const selector =
    '[data-copilot-markdown=\"true\"], ' +
    'figure[class*=\"ToolCodeBlock-module\"], ' +
    'figure[class*=\"CodeBlock-module\"]';

  const blocks = Array.from(main.querySelectorAll(selector)).map((el, i) => ({
    index: i,
    html: el.outerHTML,
    text: (el.innerText || '').replace(/\u00a0/g, ' ').trim()
  }));

  return JSON.stringify({
    url: location.href,
    title: document.title,
    blocks
  });
})();
"
    set raw_result to do JavaScript js in current tab of front window
    return raw_result
end tell
'''


@dataclass
class Block:
    index: int
    html: str
    text: str


@dataclass
class Message:
    role: str
    intro_blocks: list[Block] = field(default_factory=list)
    tool_blocks: list[Block] = field(default_factory=list)
    final_blocks: list[Block] = field(default_factory=list)


def run_osascript(script: str) -> str:
    result = subprocess.run(
        ["osascript", "-e", script],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip() or "osascript failed"
        raise RuntimeError(stderr)
    return result.stdout


def starts_with_tag(html: str, tag: str) -> bool:
    return html.lstrip().startswith(f"<{tag}")


def is_tool_figure(block: Block) -> bool:
    return starts_with_tag(block.html, "figure") and (
        "ToolCodeBlock-module" in block.html or "CodeBlock-module" in block.html
    )


def is_jsonish_text(text: str) -> bool:
    t = text.lstrip()
    return t.startswith("[") or t.startswith("{")


def is_tool_result_json(block: Block) -> bool:
    return starts_with_tag(block.html, "p") and is_jsonish_text(block.text)


def is_worklog_text(text: str) -> bool:
    t = text.strip()
    patterns = [
        r"^This is a research/analysis task",
        r"^Now let me\b",
        r"^Now I have enough context\b",
        r"^Let me do a careful\b",
        r"^I need to investigate\b",
        r"^First,?\b",
        r"^Next,?\b",
    ]
    return any(re.match(p, t) for p in patterns)


def is_final_answer_text(text: str) -> bool:
    t = text.strip()
    patterns = [
        r"^I now have\b",
        r"^Updated timeline\b",
        r"^Here is\b",
        r"^Based on\b",
        r"^Research Summary\b",
    ]
    return any(re.match(p, t) for p in patterns)


def classify_block(block: Block, seen_user: bool, previous_kind: str | None) -> str:
    if is_tool_figure(block):
        return "tool_block"

    if is_tool_result_json(block):
        return "tool_result_json"

    if starts_with_tag(block.html, "p"):
        if not seen_user:
            return "user_message"
        if is_worklog_text(block.text):
            return "assistant_worklog"
        if is_final_answer_text(block.text):
            return "assistant_final"
        if previous_kind == "assistant_final":
            return "user_message"
        return "assistant_worklog"

    return "other"


def html_fragment_to_markdown(html: str) -> str:
    soup = BeautifulSoup(html, "html.parser")

    for selector in [
        "button",
        "svg",
        "[aria-hidden='true']",
        ".sr-only",
        "[class*='CopyToClipboardButton-module']",
        "[class*='LanguageDot-module']",
        "[class*='octicon']",
    ]:
        for node in soup.select(selector):
            node.decompose()

    for tag in soup.find_all(True):
        for attr in list(tag.attrs):
            if attr in {"style", "data-testid", "node"}:
                del tag.attrs[attr]

    rendered = md(
        str(soup),
        heading_style="ATX",
        bullets="-",
        strip=["span"],
    )
    rendered = unescape(rendered)
    rendered = re.sub(r"\n{3,}", "\n\n", rendered).strip()
    return rendered


def extract_text_from_block(block: Block) -> str:
    html = block.html.strip()

    if starts_with_tag(html, "figure"):
        soup = BeautifulSoup(html, "html.parser")
        code = soup.find("code")
        pre = soup.find("pre")
        node = code or pre or soup
        return node.get_text("\n", strip=True).strip()

    return html_fragment_to_markdown(html)


def infer_code_language(block: Block) -> str:
    html = block.html

    m = re.search(r'class="([^"]*language-[^"]*)"', html, flags=re.IGNORECASE)
    if m:
        classes = m.group(1).split()
        for cls in classes:
            if cls.startswith("language-"):
                return cls.removeprefix("language-").replace("shell", "bash")

    text = block.text.strip()
    if is_jsonish_text(text):
        try:
            json.loads(text)
            return "json"
        except Exception:
            return "text"

    return "text"


def parse_blocks(raw_blocks: list[dict[str, Any]]) -> list[Block]:
    blocks: list[Block] = []
    for item in raw_blocks:
        blocks.append(
            Block(
                index=int(item["index"]),
                html=str(item["html"]),
                text=str(item["text"]),
            )
        )
    blocks.sort(key=lambda b: b.index)
    return blocks


def build_messages(blocks: list[Block]) -> list[Message]:
    messages: list[Message] = []

    current_user: Message | None = None
    current_assistant: Message | None = None

    seen_user = False
    previous_kind: str | None = None

    def ensure_assistant() -> Message:
        nonlocal current_assistant
        if current_assistant is None:
            current_assistant = Message(role="assistant")
            messages.append(current_assistant)
        return current_assistant

    for block in blocks:
        kind = classify_block(block, seen_user=seen_user, previous_kind=previous_kind)

        if kind == "user_message":
            current_user = Message(role="user", intro_blocks=[block])
            messages.append(current_user)
            current_assistant = None
            seen_user = True

        elif kind == "assistant_worklog":
            assistant = ensure_assistant()
            assistant.intro_blocks.append(block)

        elif kind == "assistant_final":
            assistant = ensure_assistant()
            assistant.final_blocks.append(block)

        elif kind in {"tool_block", "tool_result_json"}:
            assistant = ensure_assistant()
            assistant.tool_blocks.append(block)

        else:
            assistant = ensure_assistant()
            assistant.intro_blocks.append(block)

        previous_kind = kind

    return messages


def render_message(message: Message, number: int) -> str:
    parts: list[str] = []
    heading = "User" if message.role == "user" else "Assistant"
    parts.append(f"## {heading} {number}")

    if message.role == "user":
        for block in message.intro_blocks:
            text = extract_text_from_block(block)
            if text:
                parts.append(text)
        return "\n\n".join(parts)

    if message.intro_blocks:
        parts.append("### Worklog")
        for block in message.intro_blocks:
            text = extract_text_from_block(block)
            if text:
                parts.append(text)

    if message.tool_blocks:
        parts.append("### Tool output")
        for block in message.tool_blocks:
            lang = infer_code_language(block)
            text = extract_text_from_block(block)
            if not text:
                continue
            parts.append(f"```{lang}\n{text}\n```")

    if message.final_blocks:
        parts.append("### Final")
        for block in message.final_blocks:
            text = extract_text_from_block(block)
            if text:
                parts.append(text)

    return "\n\n".join(parts)


def render_transcript(messages: list[Message], source_url: str, title: str) -> str:
    parts: list[str] = [
        "# Copilot chat transcript",
        f"- Source: {source_url}",
        f"- Title: {title}",
    ]

    user_count = 0
    assistant_count = 0

    for message in messages:
        if message.role == "user":
            user_count += 1
            parts.append(render_message(message, user_count))
        else:
            assistant_count += 1
            parts.append(render_message(message, assistant_count))

    output = "\n\n---\n\n".join(part for part in parts if part.strip())
    output = re.sub(r"\n{3,}", "\n\n", output).strip() + "\n"
    return output


def main() -> int:
    parser = argparse.ArgumentParser(description="Extract Copilot chat transcript from Safari.")
    parser.add_argument(
        "--output",
        type=Path,
        default=Path("copilot_chat_transcript.md"),
        help="Markdown output path.",
    )
    parser.add_argument(
        "--stdout",
        action="store_true",
        help="Print markdown to stdout instead of writing a file.",
    )
    parser.add_argument(
        "--raw-json",
        type=Path,
        help="Optional path to save the raw JSON extracted from Safari.",
    )
    args = parser.parse_args()

    raw = run_osascript(APPLE_SCRIPT)
    data = json.loads(raw)

    if args.raw_json:
        args.raw_json.write_text(json.dumps(data, indent=2, ensure_ascii=False), encoding="utf-8")

    blocks = parse_blocks(data.get("blocks", []))
    messages = build_messages(blocks)
    transcript = render_transcript(
        messages=messages,
        source_url=str(data.get("url", "")),
        title=str(data.get("title", "")),
    )

    if args.stdout:
        sys.stdout.write(transcript)
    else:
        args.output.write_text(transcript, encoding="utf-8")
        print(f"Wrote {args.output}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
