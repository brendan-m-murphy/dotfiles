#!/usr/bin/env bash
set -euo pipefail

# Usage
#   gh-pr-comments-for-llm PR_NUMBER [owner/repo]

PR="${1:-}"
REPO="${2:-}"

if [[ -z "$PR" ]]; then
  echo "Usage: gh-pr-comments-for-llm PR_NUMBER [owner/repo]" >&2
  exit 1
fi

infer_repo () {
  git remote get-url origin \
  | sed -E 's#(git@github.com:|https://github.com/)##' \
  | sed -E 's#\.git$##'
}

if [[ -z "$REPO" ]]; then
  if ! REPO="$(infer_repo 2>/dev/null)"; then
    echo "Could not infer repository; supply owner/repo." >&2
    exit 1
  fi
fi

OWNER="${REPO%/*}"
NAME="${REPO#*/}"

gh api graphql -f query="
query {
  repository(owner: \"$OWNER\", name: \"$NAME\") {
    pullRequest(number: $PR) {
      reviewThreads(first: 100) {
        nodes {
          isResolved
          path
          comments(first: 100) {
            nodes {
              author { login }
              body
              line
              diffHunk
            }
          }
        }
      }
    }
  }
}
" \
--jq '
.data.repository.pullRequest.reviewThreads.nodes[]
| select(.isResolved == false)
| .path as $path
| .comments.nodes[]
| "
----------------------------------------
REVIEW COMMENT

Author: \(.author.login)
File: \($path)
Line: \(.line // "unknown")

Diff context:
\(.diffHunk)

Comment:
\(.body)

----------------------------------------"
'