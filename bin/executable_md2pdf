#!/usr/bin/env bash

set -Eeuo pipefail

usage() {
    printf 'Usage: %s INPUT.md [OUTPUT.pdf]\n' "$(basename "$0")" >&2
    exit 2
}

[[ $# -ge 1 && $# -le 2 ]] || usage

input=$1
output=${2:-"${input%.*}.pdf"}
pdf_engine=${PANDOC_PDF_ENGINE:-xelatex}

[[ -f "$input" ]] || {
    printf 'Error: input file not found: %s\n' "$input" >&2
    exit 1
}

command -v pandoc >/dev/null || {
    printf 'Error: pandoc is not installed.\n' >&2
    exit 1
}

command -v "$pdf_engine" >/dev/null || {
    printf "Error: PDF engine '%s' is not installed.\n" "$pdf_engine" >&2
    exit 1
}

input_dir=$(cd -- "$(dirname -- "$input")" && pwd)

# Pandoc Markdown already enables pipe tables, fenced code blocks,
# strikethrough, and task lists. These additions make it more GFM-like
# while allowing \( ... \) and \[ ... \] math.
reader='markdown+tex_math_single_backslash+autolink_bare_uris+gfm_auto_identifiers'

pandoc "$input" \
    --from="$reader" \
    --standalone \
    --pdf-engine="$pdf_engine" \
    --resource-path="$input_dir:." \
    --output="$output"

printf 'Created: %s\n' "$output"
