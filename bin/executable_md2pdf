#!/usr/bin/env bash

set -Eeuo pipefail

usage() {
    printf 'Usage: %s INPUT.md [OUTPUT.pdf]\n' "$(basename "$0")" >&2
    exit 2
}

[[ $# -ge 1 && $# -le 2 ]] || usage

input=$1
output=${2:-"${input%.*}.pdf"}

[[ -f "$input" ]] || {
    printf 'Error: input file not found: %s\n' "$input" >&2
    exit 1
}

command -v pandoc >/dev/null 2>&1 || {
    printf 'Error: pandoc is not installed or not on PATH.\n' >&2
    exit 1
}

pdf_engine=${PANDOC_PDF_ENGINE:-xelatex}

command -v "$pdf_engine" >/dev/null 2>&1 || {
    printf "Error: PDF engine '%s' is not installed.\n" "$pdf_engine" >&2
    printf 'Set PANDOC_PDF_ENGINE to xelatex, lualatex, or another installed engine.\n' >&2
    exit 1
}

input_dir=$(cd "$(dirname "$input")" && pwd)

pandoc "$input" \
    --from='commonmark_x+tex_math_single_backslash' \
    --standalone \
    --pdf-engine="$pdf_engine" \
    --resource-path="$input_dir" \
    --output="$output"

printf 'Created: %s\n' "$output"
